# Copy this file to .env and fill in your values:
#
#   cp .env.example .env
#
# The application loads .env automatically on startup (python-dotenv).
# Never commit the .env file — it is listed in .gitignore.

# ─── Telegram Notifications ──────────────────────────────────────────────────
# Bot token from @BotFather.  Leave empty to disable Telegram notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TOPIC_ID=

# ─── Proxy Credentials ───────────────────────────────────────────────────────
# Proxyverse residential proxy
PROXYVERSE_HOST=proxy.proxyverse.io:9200
PROXYVERSE_AUTH=

# Rayobyte residential proxy
RAYOBYTE_HOST=la.residential.rayobyte.com:8000
RAYOBYTE_AUTH=
