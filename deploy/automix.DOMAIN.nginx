##############################################################
#  EONX CHECKER — Nginx template
#  Subdomain convention: automix.<your-domain>
#
#  Usage:
#    1. Replace every occurrence of "automix.yourdomain.com"
#       below with your actual subdomain (e.g. automix.eonx.ph)
#    2. Copy to /etc/nginx/sites-available/automix.yourdomain.com
#    3. Symlink: ln -s /etc/nginx/sites-available/automix.yourdomain.com \
#                       /etc/nginx/sites-enabled/automix.yourdomain.com
#    4. Run: certbot --nginx -d automix.yourdomain.com
#    5. nginx -t && systemctl reload nginx
##############################################################

server {
    server_name automix.yourdomain.com;

    # SSE: buffering off + extended read timeout
    location /stream/ {
        proxy_pass http://127.0.0.1:5052;
        proxy_http_version 1.1;
        proxy_set_header Connection '';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 300;
        keepalive_timeout 300;
    }

    location / {
        proxy_pass http://127.0.0.1:5052;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300;
    }

    location ~ /\.ht {
        deny all;
    }

    listen 80;
    listen [::]:80;
    # SSL directives will be added automatically by Certbot
}
